# ──────────────────────────────────────
# 스파르타 북큐레이션 환경변수 템플릿
# 이 파일을 복사해서 실제 값을 채워주세요
# ──────────────────────────────────────

# [백엔드] apps/api/.env 에 설정
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PORT=3001

# [프론트엔드] apps/web/.env.local 에 설정
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
